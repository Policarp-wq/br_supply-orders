# Docker Hub login owner of the published images (used by docker-compose.yml)
DOCKER_USERNAME=your-dockerhub-login

# Image tag to pull. Leave as "latest" or pin to a specific commit SHA.
IMAGE_TAG=latest

# Django runtime config (production deployment)
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*

# PostgreSQL password (default user/db are supply_orders/supply_orders)
POSTGRES_PASSWORD=supply_orders
