# --- Django ---
DJANGO_SECRET_KEY=change-me-locally
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,*

# --- PostgreSQL ---
POSTGRES_DB=supply_orders
POSTGRES_USER=supply_orders
POSTGRES_PASSWORD=supply_orders
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- CORS ---
# URL фронта (Vite dev по умолчанию слушает 5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
